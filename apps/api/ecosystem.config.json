{
  "apps": [
    {
      "name": "hashmicro-test",
      "script": "dist/server.js",
      "cwd": "./apps/api",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "PORT": 4000
      },
      "env_development": {
        "NODE_ENV": "development",
        "PORT": 4000
      },
      "watch": false,
      "max_memory_restart": "256M",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "logs/error.log",
      "out_file": "logs/out.log",
      "merge_logs": true
    }
  ]
}
