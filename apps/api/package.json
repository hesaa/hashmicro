{
  "name": "@hashmicro/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start ecosystem.config.json",
    "pm2:stop": "pm2 stop hashmicro-test",
    "pm2:restart": "pm2 restart hashmicro-test",
    "pm2:logs": "pm2 logs hashmicro-test",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@hashmicro/shared-types": "workspace:*",
    "@hashmicro/shared-utils": "workspace:*",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "prisma": "^5.22.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
